# Copia a .env y rellena. NO subas .env al repo.
DATABASE_URL=postgresql+psycopg://postgres:dev@localhost:5432/tfg
# Clave de la API de Gemini (consíguela en aistudio.google.com)
GEMINI_API_KEY=...
# Modelo. gemini-3.1-flash-lite tiene una cuota gratuita amplia (~500/día).
# Verifica tus límites en aistudio.google.com y ajusta si tu cuenta usa otro.
GEMINI_MODEL=gemini-3.1-flash-lite
