# Copia a .env y rellena. NO subas .env al repo.
DATABASE_URL=postgresql+psycopg://postgres:dev@localhost:5432/tfg
# Clave de la API de Gemini (consíguela en aistudio.google.com)
GEMINI_API_KEY=...
# Opcional: clave de un SEGUNDO proyecto de Google Cloud, con billing
# habilitado, usada como respaldo SOLO si la de arriba agota su cuota (429).
# Debe ser un proyecto DISTINTO (la cuota gratis es por proyecto, no por key:
# una segunda key del MISMO proyecto no ayuda). Si la dejás vacía o sin
# definir, un 429 agotado simplemente se propaga como antes (sin respaldo).
GEMINI_API_KEY_RESPALDO=
# Modelo del CHAT (preguntas adaptativas, alto volumen). gemini-3.1-flash-lite
# tiene una cuota gratuita amplia (~500/día). Verifica tus límites en
# aistudio.google.com y ajusta si tu cuenta usa otro.
GEMINI_MODEL=gemini-3.1-flash-lite
# Modelo de los RESULTADOS que el alumno lee (análisis final, simulador,
# comparador; 1 llamada c/u). Comparte gemini-3.1-flash-lite: misma cuota
# amplia (~500/día) y evita agotar pools separados de 20/día.
GEMINI_MODEL_FINAL=gemini-3.1-flash-lite
